# Copy this file to .env and fill in your values.
# See README.md for step-by-step instructions.

# ── Database (Supabase Session Pooler) ────────────────────────────────────────
# Use the "Session pooler" URL from Supabase → Settings → Database
# URL-encode special chars in your password within DATABASE_URL (e.g. @ → %40)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres?prepared_statement_cache_size=0
SYNC_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Storage (Supabase) ────────────────────────────────────────────────────────
STORAGE_BACKEND=supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Embeddings (clause/precedent similarity) ─────────────────────────────────
# Only Isaacus Kanon 2 Embedder is used for embeddings. ISAACUS_API_KEY is required.
# See https://docs.isaacus.com/capabilities/embedding
ISAACUS_API_KEY=
ISAACUS_EMBEDDING_MODEL=kanon-2-embedder
ISAACUS_EMBEDDING_DIM=1536

# ── AI (Gemini — for explanation/doc-type only, not embeddings) ───────────────
# Get your key from: aistudio.google.com → "Get API key"
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
EXPLANATION_MODEL=gemini-2.5-flash-lite
DOCTYPE_MODEL=gemini-2.5-flash-lite

# ── App settings ──────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.85
MAX_UPLOAD_BYTES=26214400
CORS_ORIGINS=["http://localhost:3000"]

# Admin API key — required for /admin/* routes. Generate a long random secret.
# The web app must set NEXT_PUBLIC_ADMIN_API_KEY to the same value to call admin endpoints.
ADMIN_API_KEY=

# Set to true to disable AI features (useful for testing without API keys)
DISABLE_LLM=false
DISABLE_OCR=false
DISABLE_EMBEDDINGS=false
